{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Inkscape MCP",
    "version": "0.1.0",
    "identifier": "ai.fleet.inkscape-mcp",
    "build": {
        "frontendDist": "../web_sota/dist"},
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "Inkscape MCP",
                "width": 1280,
                "height": 860,
                "resizable": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:11028 ipc: http://ipc.localhost; img-src 'self' data: http://127.0.0.1:11028; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
        }
    },
    "bundle": {
        "active": true,
        "targets": ["msi", "nsis"],
        "icon": ["icons/icon.png", "icons/icon.ico"],
        "resources": [
            "resources/inkscape-mcp-backend.exe"
        ],
        "windows": {
            "webviewInstallMode": {
                "type": "downloadBootstrapper"
            },
            "nsis": {
                "installerHooks": "./windows/hooks.nsh"
            }
        }
    },
    "plugins": {}
}



