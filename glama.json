{
  "mcpServers": {
    "inkscape-mcp": {
      "command": "python",
      "args": ["-m", "inkscape_mcp.main"],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "description": "Inkscape CLI MCP server (FastMCP 3.1+): inkscape_file, inkscape_vector, inkscape_analysis, inkscape_system, list_local_models",
      "capabilities": {
        "tools": {
          "enabled": true,
          "listChanged": true
        },
        "resources": {
          "enabled": true,
          "listChanged": true,
          "subscribe": true
        },
        "prompts": {
          "enabled": true
        }
      },
      "timeout": {
        "initialize": 30000,
        "message": 120000
      },
      "metadata": {
        "version": "2.0.0b0",
        "author": "Sandra Schipal",
        "homepage": "https://github.com/sandraschi/inkscape-mcp",
        "license": "MIT",
        "tags": ["vector-graphics", "svg", "inkscape", "design", "automation", "creative-tools"],
        "categories": ["Design", "Productivity", "Creative", "Development"]
      }
    }
  }
}