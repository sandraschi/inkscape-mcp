# Inkscape MCP — Environment Configuration
# Copy this file to %LOCALAPPDATA%\ai.fleet.inkscape-mcp\.env and edit.
# The server reads these at startup. Restart after changing.

# --- Paths ---
# Path to Inkscape executable (auto-detected if not set)
# INKSCAPE_PATH=C:\Program Files\Inkscape\bin\inkscape.exe

# --- MCP Transport ---
# Transport mode: stdio (Claude Desktop), http (webapp/Tauri)
# MCP_TRANSPORT=http
# HTTP port when transport is http
MCP_PORT=11028
# Bind address
MCP_HOST=127.0.0.1

# --- Ollama (optional — for /api/generate-svg) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5-coder:latest

# --- Tauri (set automatically by backend.rs) ---
# INKSCAPE_TAURI=1
